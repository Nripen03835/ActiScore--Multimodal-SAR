{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "SECRET_KEY": "your-secret-key-here",
    "ADMIN_EMAIL": "admin@actiscore.com",
    "ADMIN_PASSWORD": "admin123"
  }
}